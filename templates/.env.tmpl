# CommerceX Environment Configuration
# Client: {{.ClientID}}
# Generated: {{.GeneratedAt}}

# Application Configuration
APP_ENV=production
PORT=3000

# Authentication
COOKIE_SECRET={{.CookieSecret}}
SUPERADMIN_USERNAME={{.AdminUsername}}
SUPERADMIN_PASSWORD={{.AdminPassword}}

# Database Configuration
DB_HOST=postgres_db
DB_PORT=5432
DB_NAME={{.DBName}}
DB_SCHEMA=public
DB_USERNAME={{.DBUsername}}
DB_PASSWORD={{.DBPassword}}

# PostgreSQL External Port (host machine)
POSTGRES_PORT={{.PostgresPort}}

# Optional: Enable SSL for database connection
ENABLE_SSL=false

# Optional: Asset CDN URL (for production)
# ASSET_URL=https://cdn.yourdomain.com/assets

# Email Configuration
EMAIL_FROM_ADDRESS="{{.BrandName}}" <noreply@{{.Domain}}>
EMAIL_VERIFY_URL={{.PublicStorefrontURL}}/verify
EMAIL_PASSWORD_RESET_URL={{.PublicStorefrontURL}}/password-reset
EMAIL_CHANGE_ADDRESS_URL={{.PublicStorefrontURL}}/verify-email-address-change
